VITE_FORMSPREE_ID=your_formspree_form_id_here
VITE_SITE_URL=https://example.com
VITE_GA_ID=

# Stripe — get these from the Stripe dashboard (Developers -> API keys).
# Use the pk_test_/sk_test_ pair while testing, pk_live_/sk_live_ to go live.
# VITE_STRIPE_PUBLISHABLE_KEY is baked into the client bundle at build time.
# STRIPE_SECRET_KEY is read by server.js at runtime and must never reach the browser.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Set ALLOW_TEST_KEYS=true ONLY for a staging deploy where testers pay with
# fake cards. It lets a test key run in production. Leave it unset on the
# real live shop.
# ALLOW_TEST_KEYS=true

# Order-notification email — emails each paid order to the shop owner.
# STRIPE_WEBHOOK_SECRET: from Stripe (Developers -> Webhooks -> your endpoint).
#   For local testing, `stripe listen` prints a whsec_ to use here instead.
# RESEND_API_KEY: from resend.com (API keys).
# ORDER_EMAIL_FROM: onboarding@resend.dev works with no domain setup, but only
#   delivers to the email that owns the Resend account. To send from your own
#   address, verify a domain in Resend and use e.g. orders@yourdomain.com.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
RESEND_API_KEY=re_your_resend_api_key
ORDER_EMAIL_FROM=onboarding@resend.dev
ORDER_EMAIL_TO=hello.softflorals@gmail.com
